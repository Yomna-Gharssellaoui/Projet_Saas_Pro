# Vercel deployment — production environment variables
# Copy this file to .env.production and fill in real values before deploying

# -----------------------------------------------
# Backend API URL — set this to your deployed backend
# Examples:
#   Railway:  https://your-app.up.railway.app/api
#   Render:   https://your-app.onrender.com/api
#   Docker Compose on VPS: https://api.yourdomain.com/api
# -----------------------------------------------
VITE_API_URL=https://your-backend-url.com/api
VITE_BACKEND_URL=https://your-backend-url.com/api

# -----------------------------------------------
# AI Service URL (Python FastAPI)
# -----------------------------------------------
VITE_AI_API_URL=https://your-ai-service-url.com/api/v1

# -----------------------------------------------
# Cloudflare Turnstile CAPTCHA (Login page)
# Get from: https://dash.cloudflare.com → Turnstile
# -----------------------------------------------
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACe2Ke1KWKMMR_7s

# -----------------------------------------------
# PayPal (optional - only if payment is used)
# -----------------------------------------------
VITE_PAYPAL_CLIENT_ID=TON_CLIENT_ID_SANDBOX
VITE_PAYPAL_MODE=sandbox
