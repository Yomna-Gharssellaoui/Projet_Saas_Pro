pipeline {
    agent any
    tools { nodejs 'node20' }

    environment {
        IMAGE_NAME = "yomnagharssellaoui/saas-frontend"
        IMAGE_TAG = "latest"
        VERCEL_TOKEN = credentials('VERCEL_TOKEN')
        VERCEL_ORG_ID = credentials('VERCEL_ORG_ID')
        VERCEL_PROJECT_ID = credentials('VERCEL_FRONTEND_PROJECT_ID')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Build') {
            steps {
                dir('Front-End') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withKubeConfig([credentialsId: 'KUBECONFIG_FILE']) {
                    sh '''
                        sed -i "s|IMAGE_TAG|${IMAGE_TAG}|g" k8s/frontend-deployment.yaml
                        kubectl apply -f k8s/frontend-deployment.yaml
                        kubectl apply -f k8s/frontend-service.yaml
                        kubectl rollout status deployment/saas-frontend -n frontend --timeout=5m
                    '''
                }
            }
        }

        stage('Deploy to Vercel') {
            steps {
                dir('Front-End') {
                    sh '''
                        npm install -g vercel
                        npx vercel pull --yes --environment=production --token=$VERCEL_TOKEN
                        npx vercel deploy --prod --token=$VERCEL_TOKEN
                    '''
                }
            }
        }
    }

    post {
        success {
            echo '✅ Frontend deployed to Kubernetes and Vercel!'
        }
        failure {
            echo '❌ Frontend deployment failed.'
        }
    }
}
