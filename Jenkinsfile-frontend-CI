pipeline {
    agent any
    tools { nodejs 'node20' }

    environment {
        SONAR_TOKEN = credentials('SONAR_FRONTEND_TOKEN')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                dir('Front-End') {
                    sh 'npm ci'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('Front-End') {
                    sh 'npm test'
                }
            }
            post {
                failure {
                    error('Frontend unit tests failed. Pipeline stopped.')
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('Front-End') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            npx sonar-scanner \
                              -Dsonar.projectKey=saas-frontend \
                              -Dsonar.sources=src \
                              -Dsonar.tests=src \
                              -Dsonar.test.inclusions=**/*.test.tsx,**/*.test.ts \
                              -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                              -Dsonar.host.url=http://localhost:9000 \
                              -Dsonar.token=$SONAR_TOKEN
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build') {
            steps {
                dir('Front-End') {
                    sh 'npm run build'
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build job: 'frontend-CD', wait: false
            }
        }
    }

    post {
        success {
            echo 'Frontend CI passed — CD pipeline triggered.'
        }
        failure {
            echo 'Frontend CI failed. Check logs above.'
        }
    }
}
