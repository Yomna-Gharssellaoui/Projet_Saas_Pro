pipeline {
    agent any
    tools { nodejs 'node20' }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                dir('Front-End') {
                    sh 'npm ci'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('Front-End') {
                    sh 'npm run test:coverage || true'
                }
            }
        }

        stage('Build') {
            steps {
                dir('Front-End') {
                    sh 'npm run build'
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build job: 'frontend-CD', wait: false
            }
        }
    }

    post {
        success {
            echo '✅ Frontend CI passed'
        }
        failure {
            echo '❌ Frontend CI failed'
        }
    }
}
