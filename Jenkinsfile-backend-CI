pipeline {
    agent any

    tools {
        nodejs 'node20'
    }

    environment {
        NODE_OPTIONS = '--max-old-space-size=512'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Back-End') {
                    sh 'npm ci --prefer-offline'
                }
            }
        }

        stage('Unit Tests + Coverage') {
            steps {
                dir('Back-End') {
                    sh 'npm run test:cov'
                }
            }
        }

        stage('SonarQube Analysis') {
            environment {
                SONAR_TOKEN = credentials('sonar-token')
            }
            steps {
                dir('Back-End') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            sonar-scanner \
                                -Dsonar.projectKey=saaspro-backend \
                                -Dsonar.projectName="SaasPro Backend"
                        '''
                    }
                }
            }
        }
    }
}
