pipeline {
    agent any
    tools {
        nodejs 'node20'
    }
    environment {
        NODE_OPTIONS = '--max-old-space-size=512'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Install Dependencies') {
            steps {
                dir('Back-End') {
                    sh 'npm ci --prefer-offline'
                }
            }
        }
        stage('Unit Tests + Coverage') {
            steps {
                dir('Back-End') {
                    sh '''
                        mkdir -p test-results
                        JEST_JUNIT_OUTPUT_DIR=test-results \
                        JEST_JUNIT_OUTPUT_NAME=junit.xml \
                        npx jest \
                          --forceExit \
                          --passWithNoTests \
                          --coverage \
                          --maxWorkers=2 \
                          --reporters=default \
                          --reporters=jest-junit
                    '''
                }
            }
        }
        stage('SonarQube Analysis') {
            environment {
                SONAR_TOKEN = credentials('SONAR_BACKEND_TOKEN')
            }
            steps {
                dir('Back-End') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            sonar-scanner \
                                -Dsonar.projectKey=saas-backend \
                                -Dsonar.projectName="SaasPro Backend" \
                                -Dsonar.sources=src \
                                -Dsonar.test.inclusions=**/*.spec.ts \
                                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                -Dsonar.coverage.exclusions=**/*.dto.ts,**/*.entity.ts,**/*.module.ts,**/*.spec.ts \
                                -Dsonar.token=$SONAR_TOKEN
                        '''
                    }
                }
            }
        }
        stage('Build') {
            steps {
                dir('Back-End') {
                    sh 'npm run build'
                }
            }
        }
        stage('Trigger CD') {
            steps {
                build job: 'backend-CD', wait: false
            }
        }
    }
    post {
        always {
            junit allowEmptyResults: true, testResults: 'Back-End/test-results/junit.xml'
        }
        success {
            echo '✅ Backend CI passed — CD pipeline triggered.'
        }
        failure {
            echo '❌ Backend CI failed. Check logs above.'
        }
    }
}
