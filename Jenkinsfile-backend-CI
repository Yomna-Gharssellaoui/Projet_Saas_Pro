pipeline {
    agent any
    
    tools {
        nodejs 'node20'
    }
    
    environment {
        NODE_OPTIONS = '--max-old-space-size=512'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            steps {
                dir('Back-End') {
                    sh 'npm ci --prefer-offline'
                }
            }
        }
        
        stage('Unit Tests + Coverage') {
            steps {
                dir('Back-End') {
                    sh 'npm run test:cov'
                }
            }
        }
        
                stage('SonarQube Analysis') {
            environment {
                SONAR_TOKEN = credentials('sonar-token')
            }
            steps {
                dir('Back-End') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            sonar-scanner \
                                -Dsonar.projectKey=saaspro-backend \
                                -Dsonar.projectName="SaasPro Backend" \
                                -Dsonar.sources=src \
                                -Dsonar.test.inclusions=**/*.spec.ts \
                                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                -Dsonar.coverage.exclusions=**/*.dto.ts,**/*.entity.ts,**/*.module.ts,**/*.spec.ts \
                                -Dsonar.token=$SONAR_TOKEN
                        '''
                    }
                }
            }
        }      
        stage('Quality Gate') {
            steps {
                timeout(time: 20, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        
        stage('Build') {
            steps {
                dir('Back-End') {
                    sh 'npm run build'
                }
            }
        }
        
        stage('Trigger CD') {
            steps {
                build job: 'backend-CD', wait: false
            }
        }
    }
    
    post {
        always {
            dir('Back-End') {
                // Optional: Publish test results and coverage (if you add reporters later)
                junit allowEmptyResults: true, testResults: '**/junit.xml'
            }
        }
        success {
            echo '✅ Backend CI passed — CD pipeline triggered.'
        }
        failure {
            echo '❌ Backend CI failed. Check logs above.'
        }
    }
}
