pipeline {
    agent any

    tools {
        nodejs 'node20'
    }

    environment {
        NODE_OPTIONS = '--max-old-space-size=512'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Back-End') {
                    sh 'npm ci --prefer-offline'
                }
            }
        }

        stage('Unit Tests + Coverage') {
            steps {
                dir('Back-End') {
                    sh 'npm run test:cov'
                }
            }
        }

        stage('SonarQube Analysis') {
    steps {
        dir('Back-End') {
            withSonarQubeEnv('SonarQube') {
                sh '''
cat > sonar-project.properties <<EOF
sonar.projectKey=saaspro-backend
sonar.projectName=SaasPro Backend
sonar.sources=src
EOF

sonar-scanner
                '''
            }
        }
    }
}
